# RabbitMQ connection URL (set automatically by docker-compose)
AMQP_URL=amqp://guest:guest@rabbitmq:5672/

# Ollama base URL (points to the ollama container in docker-compose)
OLLAMA_BASE_URL=http://ollama:11434

# Ollama model to use — must match what's been pulled into the ollama container
OLLAMA_MODEL=llama3:8b

# Timeout in seconds for a single Ollama inference call
OLLAMA_TIMEOUT=120