AMQP_URL=amqp://guest:guest@rabbitmq:5672/
OLLAMA_BASE_URL=http://ollama:11434
# Inference model — pulled automatically on first docker compose up
OLLAMA_MODEL=llama3.2:3b
# Embedding model — pulled automatically on ai-service startup
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120
# pgvector database for RAG transcript store
AI_DB_URL=postgresql://ai_user:ai_pass@ai-db:5432/ai_db